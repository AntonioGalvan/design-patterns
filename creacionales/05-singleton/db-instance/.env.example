# Copia este archivo a ".env" y pon los valores correctos.

# Cadena de conexión a tu base de datos de Neon (Postgres).
# La obtienes en https://console.neon.tech -> tu proyecto -> "Connection string".
DATABASE_URL="postgresql://usuario:password@host.neon.tech/dbname?sslmode=require"

# Puerto del API (opcional, por defecto 3000).
PORT=3000
